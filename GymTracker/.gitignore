# Xcode
#
# gitignore contributors: remember to update Global/Xcode.gitignore, Objective-C.gitignore & Swift.gitignore

## Playgrounds
Timeline.xctimeline
playground.xcworkspace

## User settings
xcuserdata/

## compatibility with Xcode 8 and earlier (ignoring not required starting Xcode 9)
*.xcscmblueprint
*.xccheckout
*.xcuserstate

## Bits used by xcodebuild to package up a project
##
!default.mode1v3
!default.mode2v3
!default.pbxuser
!default.perspectivev3

# CocoaPods
#
# We recommend against adding the Pods directory to your .gitignore. However
# you should judge for yourself, the pros and cons are mentioned at:
# https://guides.cocoapods.org/using/using-cocoapods.html#should-i-check-the-pods-directory-into-source-control
#
# Pods/
#
# Add this line if you want to avoid checking in source code from the Cards group
# Cards/

# Carthage
#
# Add this line if you want to avoid checking in source code from Carthage dependencies
# Carthage/Checkouts

# Accio dependency manager
Dependencies/
.accio/

# fastlane
#
# It is recommended to not ignore the screenshots generated by fastlane,
# however, it is heavily dependent on the user's workflow.
#
# fastlane/screenshots
# fastlane/test_output

# Polyphonia
.osx
.idea/

# Swift Package Manager
.build/
.swiftpm/

# Other
*.DS_Store
DerivedData/
*.moved-aside
*.xcuserstate
*.mobileprovision
*.hmap
*.ipa
*.dSYM.zip
*.dSYM
