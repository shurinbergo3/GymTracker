    "Цинк" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zinc"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Цинк"
          }
        }
      }
    },
    "Цинк входит в состав более 400 ферментов. Критически важен для мужского здоровья, так как напрямую влияет на производство семенной жидкости и тестостерона." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zinc is a component of over 400 enzymes. Critically important for men's health, as it directly affects semen and testosterone production."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Цинк входит в состав более 400 ферментов. Критически важен для мужского здоровья, так как напрямую влияет на производство семенной жидкости и тестостерона."
          }
        }
      }
    },
    "Цитруллин (& Аргинин)" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Citrulline (& Arginine)"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Цитруллин (& Аргинин)"
          }
        }
      }
    },
    "Цитруллин Малат (с яблочной кислотой для энергии)" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Citrulline Malate (with malic acid for energy)"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Цитруллин Малат (с яблочной кислотой для энергии)"
          }
        }
      }
    },
    "Цитруллин Малат: 6-8 грамм за 30 мин до тренировки. Аргинин менее эффективен, но работает в дозах 5-10г." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Citrulline Malate: 6-8 grams 30 min before workout. Arginine is less effective, but works at 5-10g doses."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Цитруллин Малат: 6-8 грамм за 30 мин до тренировки. Аргинин менее эффективен, но работает в дозах 5-10г."
          }
        }
      }
    },
