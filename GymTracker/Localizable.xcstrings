    "Отказ от пассивного потребления контента. Развлекать себя самому активными действиями.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schluss mit passivem Konsum von Inhalten. Beschäftige dich aktiv selbst, statt dich berieseln zu lassen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Giving up passive content consumption. Entertain yourself with active actions."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Rezygnacja z biernej konsumpcji treści. Zabawiaj się sam aktywnymi działaniami."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отказ от пассивного потребления контента. Развлекать себя самому активными действиями."
          }
        }
      }
    },
