    "Eat more than you burn — gain weight. Burn more — lose weight.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Iss mehr, als du verbrauchst – du nimmst zu. Verbrauch mehr – du nimmst ab."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Eat more than you burn — gain weight. Burn more — lose weight."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jedz więcej, niż spalasz — przybierasz. Spalaj więcej — chudniesz."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ешьте больше чем тратите — набираете вес. Тратите больше — худеете."
          }
        }
      }
    },
    "Eat protein and carbs for recovery.": {
