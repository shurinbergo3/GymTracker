    "Гормон подчинения и самопожертвования. Снижает тестостерон, чтобы избежать смертельной схватки.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Hormon der Unterordnung und Selbstaufopferung. Es senkt das Testosteron, um einen tödlichen Kampf zu vermeiden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hormone of submission and self-sacrifice. Lowers testosterone to avoid a deadly fight."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hormon podporządkowania i poświęcenia. Obniża testosteron, by uniknąć śmiertelnej walki."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Гормон подчинения и самопожертвования. Снижает тестостерон, чтобы избежать смертельной схватки."
          }
        }
      }
    },
