    "Минимум 7-9 часов. Дефицит сна убивает тестостерон и повышает кортизол.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mindestens 7-9 Stunden. Schlafmangel zerstört dein Testosteron und treibt das Cortisol hoch."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Minimum 7-9 hours. Sleep deficit kills testosterone and raises cortisol."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Minimum 7–9 godzin. Deficyt snu zabija testosteron i podnosi kortyzol."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Минимум 7-9 часов. Дефицит сна убивает тестостерон и повышает кортизол."
          }
        }
      }
    },
