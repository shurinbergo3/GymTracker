    "• Creatine: Gives strength and volume to muscles.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "• Creatin: Sorgt für Kraft und füllige Muskeln."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "• Creatine: Gives strength and volume to muscles."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "• Kreatyna: daje siłę i objętość mięśniom."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "• Креатин: Дает силу и объем мышцам."
          }
        }
      }
    },
    "• Fat burners: Don't work without diet and exercise.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "• Fatburner: Bringen nichts ohne Ernährung und Training."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "• Fat burners: Don't work without diet and exercise."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "• Spalacze tłuszczu: nie działają bez diety i treningu."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "• Жиросжигатели: Не работают без диеты и тренировок."
          }
        }
      }
    },
    "• Protein: Convenient way to get protein if you didn't have time to eat.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "• Protein: Praktische Eiweißquelle, wenn du nicht zum Essen kommst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "• Protein: Convenient way to get protein if you didn't have time to eat."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "• Białko: wygodny sposób na białko, gdy nie zdążyłeś zjeść."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "• Протеин: Удобный способ получить белок если не было времени поесть."
          }
        }
      }
    },
    "• Vitamins: Help the body function without failures.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "• Vitamine: Halten den Körper störungsfrei am Laufen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "• Vitamins: Help the body function without failures."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "• Witaminy: pomagają ciału działać bezawaryjnie."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "• Витамины: Помогают телу работать без сбоев."
          }
        }
      }
    },
    "• ГАБА (GABA) и L-теанин": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "• GABA und L-Theanin"
          }
        },
