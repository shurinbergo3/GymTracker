    },
    "Classic 6-day split: push, pull, legs — twice a week. The most popular intermediate program.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Klassischer 6-Tage-Split: Push, Pull, Beine – zweimal pro Woche. Das beliebteste Programm für Fortgeschrittene."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Classic 6-day split: push, pull, legs — twice a week. The most popular intermediate program."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Klasyczny 6-dniowy split: push, pull, legs — dwa razy w tygodniu. Najpopularniejszy plan dla średnio zaawansowanych."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Классический 6-дневный сплит: жим, тяга, ноги — по два раза в неделю. Самая популярная программа среднего уровня."
          }
        }
      }
    },
    "Classic 9-week beginner running program. 3 sessions/week, alternating run/walk intervals. Builds up to a 5K run.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Klassisches 9-Wochen-Laufprogramm für Einsteiger. 3 Einheiten/Woche im Wechsel aus Lauf- und Gehintervallen. Bringt dich bis zum durchgehenden 5-km-Lauf."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Classic 9-week beginner running program. 3 sessions/week, alternating run/walk intervals. Builds up to a 5K run."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Klasyczny 9-tygodniowy plan biegowy dla początkujących. 3 sesje w tygodniu, naprzemienne interwały bieg/marsz. Doprowadza do biegu na 5 km."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Классическая 9-недельная программа бега для начинающих. 3 раза в неделю, чередуем бег и ходьбу. Доводит до непрерывного бега 5 км."
          }
        }
      }
    },
    "Classic GVT hypertrophy method by Rolf Feser. 10 sets × 10 reps with one weight on the main lift, high volume for fast mass.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Klassisches German Volume Training nach Rolf Feser. 10 Sätze × 10 Wdh. mit einem Gewicht in der Hauptübung, hohes Volumen für schnellen Muskelaufbau."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Classic GVT hypertrophy method by Rolf Feser. 10 sets × 10 reps with one weight on the main lift, high volume for fast mass."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Klasyczny GVT na hipertrofię (Rolf Feser). 10 serii × 10 powt. z jednym ciężarem w głównym boju, wysoka objętość na szybką masę."
          }
        }
      }
    },
