    "Каждые 4-8 недель снижай объем на 50%, чтобы дать ЦНС и связкам восстановиться.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Reduziere alle 4–8 Wochen das Volumen um 50 %, damit sich ZNS und Bänder erholen können."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Every 4-8 weeks reduce volume by 50% to let CNS and tendons recover."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Co 4–8 tygodni zmniejsz objętość o 50%, by OUN i więzadła odpoczęły."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Каждые 4-8 недель снижай объем на 50%, чтобы дать ЦНС и связкам восстановиться."
          }
        }
      }
    },
