          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "2000–5000 IU dziennie rano z tłustym posiłkiem. Powyżej 5000 IU obowiązkowo dodaj 100 µg K2 (MK-7)."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "2000-5000 ME в день утром с жирной пищей. Обязательно добавлять 100 мкг К2 (MK-7) при дозировках выше 5000 ME."
          }
        }
      }
    },
