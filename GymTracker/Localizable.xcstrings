            "state" : "translated",
            "value" : "Таймер Отдыха (ВЫКЛ)"
          }
        }
      }
    },
    "Тактильный контакт, доверительные разговоры, создание глубоких связей (\"своей стаи\")." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tactile contact, confidential conversations, creating deep bonds (\"your own pack\")."
          }
        },
        "ru" : {
