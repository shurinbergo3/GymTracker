    "Знание того, что опасности нет, не останавливает выброс гормонов. Нужно работать с ощущениями, а не словами.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Knowing there's no danger doesn't stop hormone release. You need to work with sensations, not words."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Знание того, что опасности нет, не останавливает выброс гормонов. Нужно работать с ощущениями, а не словами."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wiedza, że nie ma zagrożenia, nie zatrzymuje wyrzutu hormonów. Pracuj z odczuciami, nie ze słowami."
          }
        }
      }
    },
