            "value" : "Статистика"
          }
        }
      }
    },
    "Статистика прогресса" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Progress Stats"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Статистика прогресса"
          }
        }
      }
    },
    "Стиль коуча" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Coach style"
          }
        }
      }
    },
    "Стимулирует 2-гидроксилирование эстрогенов (безопасный путь метаболизма), снижая уровень 16-гидроксиэстрона (опасный путь)." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stimulates 2-hydroxylation of estrogens (safe metabolic pathway), reducing 16-hydroxyestrone levels (dangerous pathway)."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Стимулирует 2-гидроксилирование эстрогенов (безопасный путь метаболизма), снижая уровень 16-гидроксиэстрона (опасный путь)."
          }
        }
      }
    },
    "Страх и бегство" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fear and Flight"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Страх и бегство"
          }
        }
      }
    },
    "Строительный материал. 1.6 - 2.2 г на кг веса тела." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Building material. 1.6 - 2.2 g per kg of body weight."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Строительный материал. 1.6 - 2.2 г на кг веса тела."
          }
        }
      }
    },
    "Суммарный тоннаж" : {
      "extractionState" : "manual",
      "localizations" : {
