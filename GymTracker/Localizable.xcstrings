    },
    "Глюкозамин стимулирует синтез протеогликанов (строительных блоков хряща). Хондроитин удерживает воду в хряще, обеспечивая амортизацию.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Glucosamin regt die Synthese von Proteoglykanen an (den Bausteinen des Knorpels). Chondroitin bindet Wasser im Knorpel und sorgt so für die Dämpfung."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Glucosamine stimulates proteoglycan synthesis (cartilage building blocks). Chondroitin retains water in cartilage, providing cushioning."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Glukozamina stymuluje syntezę proteoglikanów (budulca chrząstki). Chondroityna zatrzymuje wodę w chrząstce, zapewniając amortyzację."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Глюкозамин стимулирует синтез протеогликанов (строительных блоков хряща). Хондроитин удерживает воду в хряще, обеспечивая амортизацию."
          }
        }
      }
    },
