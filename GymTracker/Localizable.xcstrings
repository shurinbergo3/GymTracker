{
  "sourceLanguage": "ru",
  "strings": {
    "Внизу четыре вкладки: Тренировка, Программа, Справочник и Статистика. Листай их слева направо.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Unten vier Tabs: Training, Programm, Nachschlagewerk und Statistik. Wische sie von links nach rechts durch."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Four tabs at the bottom: Workout, Program, Reference and Stats. Swipe through them left to right."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Na dole cztery zakładki: Trening, Program, Poradnik i Statystyki. Przesuwaj je od lewej do prawej."
          }
        }
      }
    },
    "Эти показатели анализирует и ИИ-тренер - и подстраивает под них рекомендации.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Auch der KI-Coach wertet diese Werte aus - und passt seine Empfehlungen daran an."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The AI coach analyses these too - and tailors its advice to them."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Te wskaźniki analizuje też trener AI - i dopasowuje do nich porady."
          }
        }
      }
    },
