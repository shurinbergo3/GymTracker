    "Краеугольный камень успеха. Чтобы мышцы росли, требования к ним должны постоянно возрастать.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Grundstein für deinen Erfolg. Damit Muskeln wachsen, müssen die Reize ständig steigen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The cornerstone of success. For growth, demands must constantly increase."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kamień węgielny sukcesu. Żeby mięśnie rosły, wymagania muszą stale rosnąć."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Краеугольный камень успеха. Чтобы мышцы росли, требования к ним должны постоянно возрастать."
          }
        }
      }
    },
