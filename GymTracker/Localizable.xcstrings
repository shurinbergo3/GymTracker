            "state": "translated",
            "value": "Интервалы высокой интенсивности. Разгоняет метаболизм, но утомляет ЦНС."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Interwały o wysokiej intensywności. Rozpędzają metabolizm, ale męczą OUN."
          }
        }
      }
    },
