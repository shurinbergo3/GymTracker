    "Сначала растем в повторениях (8→12), потом добавляем вес и снижаем повторы (12→8).": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zuerst steigerst du die Wiederholungen (8→12), dann legst du Gewicht auf und gehst mit den Wiederholungen runter (12→8)."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "First increase reps (8→12), then add weight and drop reps (12→8)."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Najpierw rośnij w powtórzeniach (8→12), potem dodaj ciężar i zejdź z powtórzeń (12→8)."
