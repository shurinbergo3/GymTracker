    "Гормон молодости и отдыха. Превращает накопленный за день серотонин в восстановление.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hormone of youth and rest. Converts accumulated daytime serotonin into recovery."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Гормон молодости и отдыха. Превращает накопленный за день серотонин в восстановление."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hormon młodości i odpoczynku. Zamienia nagromadzoną w dzień serotoninę w regenerację."
          }
        }
      }
    },
