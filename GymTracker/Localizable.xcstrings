    },
    "Цитруллин Малат: 6-8 грамм за 30 мин до тренировки. Аргинин менее эффективен, но работает в дозах 5-10г.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Citrulline Malate: 6-8 grams 30 min before workout. Arginine is less effective, but works at 5-10g doses."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Цитруллин Малат: 6-8 грамм за 30 мин до тренировки. Аргинин менее эффективен, но работает в дозах 5-10г."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jabłczan cytruliny: 6–8 g na 30 min przed treningiem. Arginina mniej skuteczna, ale działa w dawkach 5–10 g."
          }
        }
      }
    },
