            "value": "Креатин"
          }
        }
      }
    },
    "Креатин Моногидрат": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Creatine Monohydrate"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Креатин Моногидрат"
          }
        }
      }
    },
    "Креатин — это азотсодержащая карбоновая кислота, которая участвует в энергетическом обмене в мышечных и нервных клетках. В мире спорта это «золотой стандарт». Ни одна другая добавка не имеет такой мощной доказательной базы.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Creatine is a nitrogen-containing carboxylic acid involved in energy metabolism in muscle and nerve cells. In the sports world, it is the 'gold standard'. No other supplement has such a strong evidence base."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Креатин — это азотсодержащая карбоновая кислота, которая участвует в энергетическом обмене в мышечных и нервных клетках. В мире спорта это «золотой стандарт». Ни одна другая добавка не имеет такой мощной доказательной базы."
          }
        }
      }
    },
    "Критически важный минерал для расслабления мышц, борьбы со стрессом и качественного сна. Дефицит есть почти у всех атлетов.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A critically important mineral for muscle relaxation, stress management, and quality sleep. Almost all athletes are deficient."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Критически важный минерал для расслабления мышц, борьбы со стрессом и качественного сна. Дефицит есть почти у всех атлетов."
          }
        }
      }
    },
    "Критический спад": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Critical Decline"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Критический спад"
          }
        }
      }
