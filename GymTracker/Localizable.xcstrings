    "Креатин": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Creatin"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Creatine"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kreatyna"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Креатин"
          }
        }
      }
    },
    "Креатин — это азотсодержащая карбоновая кислота, которая участвует в энергетическом обмене в мышечных и нервных клетках. В мире спорта это «золотой стандарт». Ни одна другая добавка не имеет такой мощной доказательной базы.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Creatin ist eine stickstoffhaltige Carbonsäure, die am Energiestoffwechsel in Muskel- und Nervenzellen beteiligt ist. In der Sportwelt gilt es als der „Goldstandard“. Kein anderes Supplement hat eine so starke wissenschaftliche Datenbasis."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Creatine is a nitrogen-containing carboxylic acid involved in energy metabolism in muscle and nerve cells. In the sports world, it is the 'gold standard'. No other supplement has such a strong evidence base."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kreatyna to azotowy kwas karboksylowy uczestniczący w przemianach energetycznych w komórkach mięśniowych i nerwowych. W świecie sportu to „złoty standard”. Żaden inny suplement nie ma tak mocnej bazy dowodowej."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Креатин — это азотсодержащая карбоновая кислота, которая участвует в энергетическом обмене в мышечных и нервных клетках. В мире спорта это «золотой стандарт». Ни одна другая добавка не имеет такой мощной доказательной базы."
          }
        }
      }
    },
    "Креатин Моногидрат": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Creatin Monohydrat"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Creatine Monohydrate"
          }
