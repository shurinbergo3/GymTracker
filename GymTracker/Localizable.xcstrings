    "Без движения не накапливается аденозин (нейромедиатор усталости).": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ohne Bewegung sammelt sich kein Adenosin an (der Botenstoff der Müdigkeit)."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Without movement, adenosine (fatigue neurotransmitter) doesn't accumulate."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bez ruchu nie kumuluje się adenozyna (neuroprzekaźnik zmęczenia)."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Без движения не накапливается аденозин (нейромедиатор усталости)."
          }
        }
      }
    },
    "Без опыта": {
      "extractionState": "manual",
      "localizations": {
        "de": {
