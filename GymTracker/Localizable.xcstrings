    "Связывается с GABA-рецепторами в мозге, вызывая торможение нервных импульсов (снимает тревожность).": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bindet an die GABA-Rezeptoren im Gehirn und hemmt so die Nervenimpulse (lindert Angst)."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Binds to GABA receptors in the brain, causing inhibition of nerve impulses (relieves anxiety)."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wiąże się z receptorami GABA w mózgu, hamuje impulsy nerwowe (redukuje lęk)."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Связывается с GABA-рецепторами в мозге, вызывая торможение нервных импульсов (снимает тревожность)."
          }
        }
      }
    },
