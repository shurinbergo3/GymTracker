    "Креатин" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Creatine"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Креатин"
          }
        }
      }
    },
    "Креатин — это азотсодержащая карбоновая кислота, которая участвует в энергетическом обмене в мышечных и нервных клетках. В мире спорта это «золотой стандарт». Ни одна другая добавка не имеет такой мощной доказательной базы." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Creatine is a nitrogen-containing carboxylic acid involved in energy metabolism in muscle and nerve cells. In the sports world, it is the 'gold standard'. No other supplement has such a strong evidence base."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Креатин — это азотсодержащая карбоновая кислота, которая участвует в энергетическом обмене в мышечных и нервных клетках. В мире спорта это «золотой стандарт». Ни одна другая добавка не имеет такой мощной доказательной базы."
          }
        }
      }
    },
