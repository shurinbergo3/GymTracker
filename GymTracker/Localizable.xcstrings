            "state": "translated",
            "value": "Nutrition Guide"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przewodnik żywienia"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Гид по Питанию"
          }
        }
      }
    },
    "nutrition_intro_text": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Richtige Ernährung ist keine Diät, sondern Treibstoff für den Erfolg. Essen beeinflusst Energie, Stimmung und Regeneration. Keine komplizierten Formeln, nur die Grundlagen, die wirklich funktionieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Proper nutrition isn't a diet, it's fuel for victory. Food affects energy, mood, and recovery. No complex formulas, just basics that work."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Prawidłowe odżywianie to nie dieta — to paliwo do zwycięstwa. Jedzenie wpływa na energię, nastrój i regenerację. Bez skomplikowanych wzorów, tylko podstawy, które działają."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Правильное питание — это не диета, это топливо для победы. Еда влияет на энергию, настроение и восстановление. Никаких сложных формул, только основы, которые работают."
          }
        }
      }
    },
