    "«Кругом враги», депрессивность, рабство страстей, невозможность отказать себе во вредном.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "'Enemies everywhere', depression, slavery to passions, inability to deny yourself harmful things."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "«Кругом враги», депрессивность, рабство страстей, невозможность отказать себе во вредном."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "„Wszędzie wrogowie”, depresyjność, niewola namiętności, brak odmowy szkodliwym pokusom."
          }
        }
      }
    },
