    "Третий день без зала. XP пошёл вниз — одна тренировка вернёт пик.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dritter Tag ohne Gym. Deine XP sinken — ein Training bringt dich zurück auf den Höchststand."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Third day without the gym. XP is dropping — one workout will bring back your peak."
          }
        },
        "pl": {
