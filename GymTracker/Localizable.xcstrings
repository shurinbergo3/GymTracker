    "Norwegian VO2max protocol. 4 minutes hard (90-95% HR max) / 3 minutes easy × 4 rounds. The most efficient cardio for VO2max.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Norwegisches VO2max-Protokoll. 4 Minuten hart (90–95% der max. Herzfrequenz) / 3 Minuten locker × 4 Runden. Das effektivste Cardio für deine VO2max."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Norwegian VO2max protocol. 4 minutes hard (90-95% HR max) / 3 minutes easy × 4 rounds. The most efficient cardio for VO2max."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Norweski protokół VO2max. 4 min mocno (90–95% HR max) / 3 min lekko × 4 rundy. Najbardziej efektywne kardio na VO2max."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Норвежский протокол на VO2max. 4 минуты в зоне 90-95% от ЧСС макс / 3 минуты восстановления × 4 раунда. Самое эффективное кардио на VO2max."
          }
        }
      }
    },
