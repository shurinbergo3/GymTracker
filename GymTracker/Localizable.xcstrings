    "Степпер (Шаг через ступеньку, Перекрестный шаг)": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Stair Climber (Stufe überspringen, Kreuzschritt)"
          }
        },
        "en": {
          "stringUnit": {
