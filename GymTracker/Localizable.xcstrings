          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Бескомпромиссность, четкость действий («подумал — сделал»)."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bezkompromisowość, klarowność działań („pomyślałem — zrobiłem”)."
          }
        }
      }
    },
