    "Разбирает каждую тренировку, отвечает на вопросы и подсказывает, что менять. Нажми на карточку, чтобы открыть диалог.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wertet jedes Training aus, beantwortet Fragen und schlägt vor, was du ändern solltest. Tippe auf die Karte, um den Chat zu öffnen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reviews every workout, answers your questions and suggests what to change. Tap the card to open the chat."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Analizuje każdy trening, odpowiada na pytania i podpowiada, co zmienić. Dotknij karty, aby otworzyć czat."
          }
        }
      }
    },
