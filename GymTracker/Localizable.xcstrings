    "2-day hypertrophy split. Day 1 — back, chest, biceps, triceps. Day 2 — legs and shoulders. Beginner-friendly volume.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "2-day hypertrophy split. Day 1 — back, chest, biceps, triceps. Day 2 — legs and shoulders. Beginner-friendly volume."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сплит верх/низ на гипертрофию. День 1 — спина, грудь, бицепс, трицепс. День 2 — ноги и плечи. Подходит для среднего уровня."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "2-dniowy split na hipertrofię. Dzień 1 — plecy, klatka, biceps, triceps. Dzień 2 — nogi i barki. Objętość przyjazna dla początkujących."
          }
        }
      }
    },
