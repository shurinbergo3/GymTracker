    "ТЕСТОСТЕРОН" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TESTOSTERONE"
          }
        }
      }
    },
    "Тестостерон ощущается как уверенность в себе, внушение уважения к себе окружающим." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Testosterone feels like pure self-confidence; it's the kind of inner strength that earns you respect without saying a word."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Тестостерон ощущается как уверенность в себе, внушение уважения к себе окружающим."
          }
        }
      }
    },
    "Техника выполнения" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Exercise Technique"
          }
        },
        "ru" : {
