          "stringUnit": {
            "state": "translated",
            "value": "Классические отжимания от пола. Тело - прямая линия, опускайтесь до касания грудью пола."
          }
        }
      }
    },
    "Классический жим штанги лежа": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Classic Barbell Bench Press"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Классический жим штанги лежа"
          }
        }
      }
    },
    "Классический жим штанги лежа. Опускайте на грудь, выжмите вверх. Лопатки сведены.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Classic barbell bench press. Lower to chest, press up. Shoulder blades squeezed."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Классический жим штанги лежа. Опускайте на грудь, выжмите вверх. Лопатки сведены."
          }
        }
      }
    },
    "Кластеры (Clusters)": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clusters"
