    "Давать выход эмоциям (петь, танцевать, плакать), не запирать их в себе.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lass deinen Emotionen freien Lauf (singen, tanzen, weinen), statt sie in dich hineinzufressen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Give emotions an outlet (sing, dance, cry), don't bottle them up."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Daj emocjom ujście (śpiewaj, tańcz, płacz), nie zamykaj ich w sobie."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Давать выход эмоциям (петь, танцевать, плакать), не запирать их в себе."
          }
        }
      }
    },
