      }
    },
    "Креа-алкалин" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kre-Alkalyn"
          }
        },
        "ru" : {
