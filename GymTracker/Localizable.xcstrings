    "DIM (более стабильная форма, чем Индол)": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "DIM (more stable form than Indole)"
          }
        },
        "ru": {
