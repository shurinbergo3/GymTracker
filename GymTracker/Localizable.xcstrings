    "Proper nutrition isn't a diet, it's fuel for victory. Food affects energy, mood, and recovery. No complex formulas, just basics that work.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Richtige Ernährung ist keine Diät, sondern Treibstoff für den Erfolg. Essen beeinflusst Energie, Stimmung und Regeneration. Keine komplizierten Formeln, nur Basics, die funktionieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Proper nutrition isn't a diet, it's fuel for victory. Food affects energy, mood, and recovery. No complex formulas, just basics that work."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Prawidłowe odżywianie to nie dieta — to paliwo do zwycięstwa. Jedzenie wpływa na energię, nastrój i regenerację. Bez skomplikowanych wzorów, tylko podstawy, które działają."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Proper nutrition isn't a diet, it's fuel for victory. Food affects energy, mood, and recovery. No complex formulas, just basics that work."
          }
        }
      }
    },
