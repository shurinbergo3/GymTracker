    "Пульс покоя выше нормы на %d уд/мин — поспи лишний час и убавь интенсивность.": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein Ruhepuls liegt %d Schläge/min über dem Normalwert – schlaf eine Stunde länger und drossle die Intensität."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Resting heart rate is %d bpm above normal — get an extra hour of sleep and dial back the intensity."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tętno spoczynkowe jest o %d ud/min powyżej normy — prześpij dodatkową godzinę i zmniejsz intensywność."
