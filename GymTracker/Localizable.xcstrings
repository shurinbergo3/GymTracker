    "Тремор, суета, невозможность сфокусироваться, желание убежать «куда глаза глядят».": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zittern, Hektik, fehlende Konzentration, der Drang, einfach loszurennen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tremor, fuss, inability to focus, desire to run 'wherever your eyes look'."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Drżenie, pośpiech, brak skupienia, chęć ucieczki „gdziekolwiek”."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Тремор, суета, невозможность сфокусироваться, желание убежать «куда глаза глядят»."
          }
        }
      }
    },
