    "Дефицит внимания (СДВГ), скука, поиск дешевого дофамина.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Attention deficit (ADHD), boredom, seeking cheap dopamine."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Дефицит внимания (СДВГ), скука, поиск дешевого дофамина."
          }
        }
      }
    },
    "Дефицит внимания, невозможность сфокусироваться, скука, поиск легкого дофамина.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Attention deficit and inability to focus. Persistent boredom and a drive for cheap dopamine."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Дефицит внимания, невозможность сфокусироваться, скука, поиск легкого дофамина."
          }
        }
      }
    },
    "Джампинг Джек": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Jumping Jacks"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Джампинг Джек"
          }
        }
      }
    },
    "Динамика: Взрывное движение. Подъем грифа с пола с разворотом корпуса и перехватом в верхней точке. Тренирует передачу усилия от бедер к плечам (трансфер силы для единоборств).": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Dynamics: Explosive movement. Lift bar from floor with torso rotation & re-grip at top. Trains force transfer from hips to shoulders (power transfer for combat sports)."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Динамика: Взрывное движение. Подъем грифа с пола с разворотом корпуса и перехватом в верхней точке. Тренирует передачу усилия от бедер к плечам (трансфер силы для единоборств)."
          }
        }
      }
    },
    "Дистанция": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Distance"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Дистанция"
          }
        }
      }
    },
    "Дистанция 50–200 м. Максимальная скорость.\n\nКлючи: между спринтами — полное восстановление (2–3 мин). Для развития мощности и анаэробной системы.": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Distance: 50–200 m. Maximum speed.\n\nKeys: full recovery between sprints (2–3 min). Develops power and the anaerobic system."
          }
        }
      }
    },
    "Для роста повысьте нагрузку": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "To grow, increase the load"
