    "Техника выполнения" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Exercise Technique"
          }
        },
        "ru" : {
          "stringUnit" : {
