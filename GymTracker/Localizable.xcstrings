    "Упал на %1$d %2$@ и %3$@ XP. Тренировка восстановит прогресс — и доведёт обратно к Уровню %4$d.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$d %2$@ und %3$@ XP verloren. Ein Training holt deinen Fortschritt zurück — und bringt dich wieder auf Level %4$d."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Dropped %1$d %2$@ and %3$@ XP. A workout will restore progress — and bring you back to Level %4$d."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Spadek o %1$d %2$@ i %3$@ XP. Trening odzyska postęp — i wróci do Poziomu %4$d."
          }
        }
      }
    },
