    },
    "Человек нервный, раздражительный, злобный.": {},
    "Человек чувствует себя замечательно, бодро.": {},
    "Чередование периодов максимального ускорения (спринт) и активного отдыха (легкий бег или ходьба). Например: 30 сек спринт / 30 сек отдых. Эффективно для жиросжигания.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Alternating maximum acceleration periods (sprint) and active rest (light jog or walk). Example: 30 sec sprint / 30 sec rest. Effective for fat burning."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Чередование периодов максимального ускорения (спринт) и активного отдыха (легкий бег или ходьба). Например: 30 сек спринт / 30 сек отдых. Эффективно для жиросжигания."
          }
        }
      }
    },
    "Чувствительность важнее количества": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sensitivity Matters More Than Quantity"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Чувствительность важнее количества"
          }
        }
      }
    },
    "Чувствительность к инсулину": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Insulin Sensitivity"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Чувствительность к инсулину"
          }
        }
      }
    },
    "Чувствительность рецепторов восстанавливается только при длительном отсутствии взаимодействия с гормоном.": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Receptor sensitivity recovers only with prolonged absence of interaction with the hormone."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Чувствительность рецепторов восстанавливается только при длительном отсутствии взаимодействия с гормоном."
          }
        }
      }
    },
    "Шаг вперед, опуститесь до параллели. Колено не выходит за носок. Отталкивайтесь передней ногой.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Step forward, lower to parallel. Knee doesn't pass toes. Push off with front leg."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Шаг вперед, опуститесь до параллели. Колено не выходит за носок. Отталкивайтесь передней ногой."
          }
        }
      }
    },
    "Шаг назад. Опуститесь, отталкивайтесь назад. Меньше нагрузки на колени, чем при выпадах вперед.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Step back. Lower down, push back. Less knee stress than forward lunges."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Шаг назад. Опуститесь, отталкивайтесь назад. Меньше нагрузки на колени, чем при выпадах вперед."
          }
        }
      }
    },
    "Широкая постановка ног, носки врозь. Хват узкий. Спина вертикальнее, чем в классике. Больше работают ноги и ягодицы.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Wide stance, toes out. Narrow grip. Back more upright than conventional. More leg and glute work."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Широкая постановка ног, носки врозь. Хват узкий. Спина вертикальнее, чем в классике. Больше работают ноги и ягодицы."
          }
        }
      }
    },
    "Широкая постановка ног, носки развернуты. Больше работы приводящих и ягодиц.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Wide stance, toes turned out. More adductor and glute work."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Широкая постановка ног, носки развернуты. Больше работы приводящих и ягодиц."
          }
        }
      }
    },
    "Широкая стойка. Перенос веса на одну ногу, сгибая ее в колене. Вторая нога прямая. Спина ровная.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Wide stance. Shift weight to one leg, bending at knee. Other leg straight. Back straight."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Широкая стойка. Перенос веса на одну ногу, сгибая ее в колене. Вторая нога прямая. Спина ровная."
          }
        }
      }
    },
    "Широкий хват. Мощный подрыв штанги с пола за счет ног и спины, полное выпрямление ('тройное разгибание') и уход в глубокий сед, принимая штангу над головой. Требует гибкости плеч.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Wide grip. Powerful barbell pull from floor using legs and back, full extension ('triple extension'), and drop into deep squat catching bar overhead. Requires shoulder flexibility."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Широкий хват. Мощный подрыв штанги с пола за счет ног и спины, полное выпрямление ('тройное разгибание') и уход в глубокий сед, принимая штангу над головой. Требует гибкости плеч."
          }
        }
      }
    },
    "Широчайшие": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lats"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Широчайшие"
          }
        }
      }
    },
    "Шраги с гантелями": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Dumbbell Shrugs"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Шраги с гантелями"
          }
        }
      }
    },
    "Шраги со штангой": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Barbell Shrugs"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Шраги со штангой"
          }
        }
      }
    },
    "Штанга за спиной в опущенных руках. Сгибаем кисти вверх. Качает предплечья.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Barbell behind back in lowered hands. Curl wrists up. Builds forearms."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Штанга за спиной в опущенных руках. Сгибаем кисти вверх. Качает предплечья."
          }
        }
      }
    },
    "Штанга на груди. Короткий подсед и выталкивание штанги вверх с одновременным уходом под нее (в ножницы или стойку). Руки выпрямляются мгновенно.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bar on chest. Short dip and drive bar up while simultaneously dropping under it (split or power). Arms lock out instantly."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Штанга на груди. Короткий подсед и выталкивание штанги вверх с одновременным уходом под нее (в ножницы или стойку). Руки выпрямляются мгновенно."
          }
        }
      }
    },
    "Штанга ниже на спине. Больший наклон корпуса, больше работы ягодиц и бицепса бедра.": {
      "localizations": {
