    "• Витамины: Помогают организму работать без сбоев.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "• Vitamins: Help the body run smoothly."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "• Витамины: Помогают организму работать без сбоев."
          }
        }
      }
    },
    "• ГАБА (GABA) и L-теанин": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "• GABA & L-Theanine"
          }
        },
        "ru": {
