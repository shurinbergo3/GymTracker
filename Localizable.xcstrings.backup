    "• Жиросжигатели: Не работают без диеты и спорта.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "• Fat Burners: Won't work without diet & training."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "• Жиросжигатели: Не работают без диеты и спорта."
